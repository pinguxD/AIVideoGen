YOUTUBE_API_KEY=YOUR_KEY_HERE
MY_CHANNEL_ID=
MY_CHANNEL_HANDLE=@arnovcs-v2m
CHANNEL_SYNC_HOURS=6
CHANNEL_MAX_UPLOADS=100
DAYS_BACK=7
REGION_CODE=US
MAX_RESULTS_PER_QUERY=20
MAX_TOTAL_CANDIDATES=250
MAX_CHANNEL_SUBS=50000
MIN_VIEWS=1000
MIN_PRODUCTION_SCORE=60
MIN_AUTO_SCORE=50

# Raw gameplay clip miner
# Put long recordings in assets/raw_gameplay/. Set true when you want Trend Radar to auto-cut reusable clips.
MINE_RAW_GAMEPLAY=false
MAX_MINED_CLIPS_PER_FILE=8
MINED_CLIP_LENGTH_SECONDS=9

# Optional: enables automatic Creative Commons sound search/download.
# Request an API key at https://freesound.org/apiv2/apply
FREESOUND_API_KEY=YOUR_FREESOUND_KEY_HERE
